# Copy to .env and fill in values.

# OpenRouter API key. Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Pinned model id. Must support structured output / tool use.
# Avoid "openrouter/auto" — the app rejects it on purpose.
OPENROUTER_MODEL=openai/gpt-4.1-mini

# SQLite database file path. Created if it does not exist.
# Deliberately cannot be ":memory:" because session review commands need a persistent file.
DATABASE_PATH=./quiz.db
